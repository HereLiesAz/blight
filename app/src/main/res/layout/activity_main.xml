<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <!-- Main Content -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#0b0b0b">

        <org.osmdroid.views.MapView
            android:id="@+id/map"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- Status Overlays -->
        <TextView
            android:id="@+id/sync_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="20dp"
            android:background="@drawable/rounded_bg_green"
            android:fontFamily="monospace"
            android:paddingHorizontal="15dp"
            android:paddingVertical="5dp"
            android:text="📡 ONLINE"
            android:textColor="#0f0"
            android:textSize="12sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/scrape_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_centerHorizontal="true"
            android:layout_marginBottom="100dp"
            android:background="#FFBF00"
            android:fontFamily="monospace"
            android:paddingHorizontal="15dp"
            android:paddingVertical="5dp"
            android:text="🔄 Triggering Update..."
            android:textColor="#000"
            android:textSize="12sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/loading_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:background="@drawable/rounded_bg_amber"
            android:fontFamily="monospace"
            android:padding="12dp"
            android:text="Scanning Sector..."
            android:textColor="#FFBF00"
            android:textSize="16sp"
            android:visibility="gone" />

        <!-- Camo Trigger (Top Left) -->
        <View
            android:id="@+id/camo_trigger"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_alignParentStart="true"
            android:layout_alignParentTop="true"
            android:background="@android:color/transparent" />

        <!-- Timeline Panel (Bottom Left) -->
        <LinearLayout
            android:id="@+id/time_panel"
            android:layout_width="250dp"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_alignParentStart="true"
            android:layout_margin="20dp"
            android:background="@drawable/rounded_bg_dark"
            android:orientation="vertical"
            android:padding="10dp">

            <TextView
                android:id="@+id/time_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:gravity="center"
                android:text="⏳ Timeline: ALL TIME"
                android:textColor="#FFBF00"
                android:textSize="12sp" />

            <SeekBar
                android:id="@+id/time_slider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="12"
                android:progress="12" />
        </LinearLayout>

        <!-- HUD Controls (Bottom Right) -->
        <LinearLayout
            android:id="@+id/hud_controls"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_alignParentEnd="true"
            android:layout_margin="20dp"
            android:orientation="vertical">

            <Button
                android:id="@+id/btn_filters"
                style="@style/HudButton"
                android:text="FILTERS" />

            <Button
                android:id="@+id/btn_graffiti_filter"
                style="@style/HudButton"
                android:text="🎨 Graffiti: All" />

            <Button
                android:id="@+id/btn_color_mode"
                style="@style/HudButton"
                android:text="🎨 Color: Status" />

            <Button
                android:id="@+id/btn_pins"
                style="@style/HudButton"
                android:text="📂 Pins" />

            <Button
                android:id="@+id/btn_list_blighted"
                style="@style/HudButton"
                android:text="📋 LIST BLIGHTED" />

            <Button
                android:id="@+id/btn_list_view"
                style="@style/HudButton"
                android:text="📋 List View" />

            <Button
                android:id="@+id/btn_update_db"
                style="@style/HudButton"
                android:text="🔄 Update DB" />

            <Button
                android:id="@+id/btn_beam_intel"
                style="@style/HudButton"
                android:text="🕸️ Beam Intel" />

            <Button
                android:id="@+id/btn_track_gps"
                style="@style/HudButton"
                android:text="📍 Track GPS" />

            <Button
                android:id="@+id/btn_ghost"
                style="@style/HudButtonGhost"
                android:text="⚠️ GHOST" />
        </LinearLayout>

    </RelativeLayout>

    <!-- Filter Drawer (Right Side) -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/filter_drawer"
        android:layout_width="320dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="#f20b0b0b"
        android:theme="@style/Theme.RedBlightDistrict">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Preset -->
                <TextView style="@style/FilterHeader" android:text="Preset" />
                <Spinner
                    android:id="@+id/spinner_preset"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/spinner_bg"
                    android:padding="8dp" />

                <!-- Property Type -->
                <TextView style="@style/FilterHeader" android:text="Property type" />
                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipgroup_property_type"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <com.google.android.material.chip.Chip android:id="@+id/chip_residential" style="@style/FilterChip" android:text="Residential" android:checked="true"/>
                    <com.google.android.material.chip.Chip android:id="@+id/chip_commercial" style="@style/FilterChip" android:text="Commercial" android:checked="true"/>
                    <com.google.android.material.chip.Chip android:id="@+id/chip_mixed" style="@style/FilterChip" android:text="Mixed-use" android:checked="true"/>
                    <com.google.android.material.chip.Chip android:id="@+id/chip_vacant" style="@style/FilterChip" android:text="Vacant lot" android:checked="true"/>
                </com.google.android.material.chip.ChipGroup>

                <!-- Deadline Window -->
                <TextView style="@style/FilterHeader" android:text="Deadline window" />
                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipgroup_deadline"
                    app:singleSelection="true"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <com.google.android.material.chip.Chip android:id="@+id/chip_dl_all" style="@style/FilterChip" android:text="All" android:checked="true"/>
                    <com.google.android.material.chip.Chip android:id="@+id/chip_dl_lt7" style="@style/FilterChip" android:text="&lt;7d" />
                    <com.google.android.material.chip.Chip android:id="@+id/chip_dl_7_14" style="@style/FilterChip" android:text="7-14d" />
                    <com.google.android.material.chip.Chip android:id="@+id/chip_dl_gt14" style="@style/FilterChip" android:text="&gt;14d" />
                    <com.google.android.material.chip.Chip android:id="@+id/chip_dl_expired" style="@style/FilterChip" android:text="Expired" />
                </com.google.android.material.chip.ChipGroup>

                <!-- Has Structure -->
                <TextView style="@style/FilterHeader" android:text="Has structure" />
                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipgroup_structure"
                    app:singleSelection="true"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <com.google.android.material.chip.Chip android:id="@+id/chip_struct_yes" style="@style/FilterChip" android:text="Yes" />
                    <com.google.android.material.chip.Chip android:id="@+id/chip_struct_no" style="@style/FilterChip" android:text="No" />
                    <com.google.android.material.chip.Chip android:id="@+id/chip_struct_both" style="@style/FilterChip" android:text="Both" android:checked="true"/>
                </com.google.android.material.chip.ChipGroup>

                <!-- Days Under Blight -->
                <TextView style="@style/FilterHeader" android:text="Days under blight (min)" />
                <SeekBar
                    android:id="@+id/slider_days_blighted"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="3650"
                    android:progress="0" />
                <TextView
                    android:id="@+id/label_days_blighted"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="≥ 0 days"
                    android:textColor="#eee"
                    android:textSize="12sp" />

                <!-- Repeat Offender -->
                <CheckBox
                    android:id="@+id/check_repeat_offender"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Repeat offender (≥2 cases)"
                    android:textColor="#FFBF00"
                    android:buttonTint="#FFBF00" />

                <!-- Active Rehab -->
                <TextView style="@style/FilterHeader" android:text="Active rehab" />
                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipgroup_rehab"
                    app:singleSelection="true"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <com.google.android.material.chip.Chip android:id="@+id/chip_rehab_exclude" style="@style/FilterChip" android:text="Exclude" />
                    <com.google.android.material.chip.Chip android:id="@+id/chip_rehab_all" style="@style/FilterChip" android:text="All" android:checked="true"/>
                    <com.google.android.material.chip.Chip android:id="@+id/chip_rehab_only" style="@style/FilterChip" android:text="Only" />
                </com.google.android.material.chip.ChipGroup>

                <!-- Cluster -->
                <TextView style="@style/FilterHeader" android:text="Cluster" />
                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipgroup_cluster"
                    app:singleSelection="true"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <com.google.android.material.chip.Chip android:id="@+id/chip_cluster_solo" style="@style/FilterChip" android:text="Solo" />
                    <com.google.android.material.chip.Chip android:id="@+id/chip_cluster_cluster" style="@style/FilterChip" android:text="Cluster" />
                    <com.google.android.material.chip.Chip android:id="@+id/chip_cluster_all" style="@style/FilterChip" android:text="All" android:checked="true"/>
                </com.google.android.material.chip.ChipGroup>

                <!-- Demolition -->
                <TextView style="@style/FilterHeader" android:text="Demolition" />
                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipgroup_demo"
                    app:singleSelection="true"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <com.google.android.material.chip.Chip android:id="@+id/chip_demo_all" style="@style/FilterChip" android:text="All" android:checked="true"/>
                    <com.google.android.material.chip.Chip android:id="@+id/chip_demo_pending" style="@style/FilterChip" android:text="Pending" />
                    <com.google.android.material.chip.Chip android:id="@+id/chip_demo_permitted" style="@style/FilterChip" android:text="Permitted" />
                    <com.google.android.material.chip.Chip android:id="@+id/chip_demo_completed" style="@style/FilterChip" android:text="Completed" />
                    <com.google.android.material.chip.Chip android:id="@+id/chip_demo_none" style="@style/FilterChip" android:text="None" />
                </com.google.android.material.chip.ChipGroup>

                <!-- Permits -->
                <TextView style="@style/FilterHeader" android:text="Recent permits (min in 365d)" />
                <SeekBar
                    android:id="@+id/slider_permits"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="10"
                    android:progress="0" />
                <TextView
                    android:id="@+id/label_permits"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="≥ 0 permits"
                    android:textColor="#eee"
                    android:textSize="12sp" />

                <!-- Actions -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp"
                    android:weightSum="2">

                    <Button
                        android:id="@+id/btn_filter_reset"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:backgroundTint="#333"
                        android:textColor="#eee"
                        android:text="Reset" />

                    <Button
                        android:id="@+id/btn_filter_apply"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:backgroundTint="#FFBF00"
                        android:textColor="#0b0b0b"
                        android:text="Apply" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>
    </com.google.android.material.navigation.NavigationView>

    <!-- Modals (Hidden by default) -->

    <!-- Camo UI -->
    <RelativeLayout
        android:id="@+id/camo_ui"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#87CEEB"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="150dp"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="New Orleans"
                android:textColor="#fff"
                android:textSize="24sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="72°"
                android:textColor="#fff"
                android:textSize="80sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Partly Cloudy"
                android:textColor="#fff"
                android:textSize="24sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="H:78° L:65°"
                android:textColor="#fff"
                android:textSize="24sp" />
        </LinearLayout>
    </RelativeLayout>

    <!-- QR Modal -->
    <FrameLayout
        android:id="@+id/qr_modal"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="#fff"
            android:padding="20dp"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/qr_image"
                android:layout_width="256dp"
                android:layout_height="256dp" />

            <Button
                android:id="@+id/btn_qr_close"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:backgroundTint="#333"
                android:text="Close Link" />
        </LinearLayout>
    </FrameLayout>

    <!-- Blighted List Modal -->
    <FrameLayout
        android:id="@+id/blighted_modal"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_margin="20dp"
            android:background="@drawable/rounded_bg_dark_red_border"
            android:padding="20dp"
            android:orientation="vertical">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Blighted Properties in View"
                    android:textColor="#ff0000"
                    android:textSize="20sp"
                    android:textStyle="bold" />
                <ImageButton
                    android:id="@+id/btn_blighted_close"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:background="@android:color/transparent"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    app:tint="#fff" />
            </RelativeLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_blighted"
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:layout_marginTop="10dp" />
        </LinearLayout>
    </FrameLayout>

    <!-- Database List Modal -->
    <FrameLayout
        android:id="@+id/list_modal"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#0b0b0b"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <Button
                android:id="@+id/btn_list_close"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:backgroundTint="#900"
                android:text="X" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Database Records"
                android:textColor="#eee"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_database"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </LinearLayout>
    </FrameLayout>

    <!-- Pin Categories Modal -->
    <FrameLayout
        android:id="@+id/pin_cat_modal"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#D9000000"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_margin="20dp"
            android:background="@drawable/rounded_bg_dark_amber_border"
            android:padding="20dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📂 Pin categories"
                android:textColor="#FFBF00"
                android:textSize="20sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_pin_cats"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginTop="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp">

                <EditText
                    android:id="@+id/edit_cat_emoji"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:background="@drawable/edittext_bg"
                    android:hint="📍"
                    android:textColorHint="#888"
                    android:textColor="#eee"
                    android:padding="8dp"
                    android:gravity="center"
                    android:maxLength="4" />

                <EditText
                    android:id="@+id/edit_cat_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/edittext_bg"
                    android:hint="Category name"
                    android:textColorHint="#888"
                    android:textColor="#eee"
                    android:padding="8dp" />

                <Button
                    android:id="@+id/btn_add_cat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:backgroundTint="#FFBF00"
                    android:textColor="#000"
                    android:text="Add" />
            </LinearLayout>

            <Button
                android:id="@+id/btn_pin_cat_close"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:backgroundTint="#333"
                android:text="Close" />
        </LinearLayout>
    </FrameLayout>

</androidx.drawerlayout.widget.DrawerLayout>
